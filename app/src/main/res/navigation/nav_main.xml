<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_main"
    app:startDestination="@id/loginFragment">

    <!-- Global action: logout → login, чистит весь back stack -->
    <action
        android:id="@+id/action_logout"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/nav_main"
        app:popUpToInclusive="true" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.exelgramm.ui.auth.LoginFragment"
        android:label="">
        <action
            android:id="@+id/action_login_to_chat"
            app:destination="@id/nav_chat"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_chat"
        android:name="com.example.exelgramm.ui.chat.ChatFragment"
        android:label="@string/nav_chat" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.exelgramm.ui.profile.ProfileFragment"
        android:label="@string/nav_profile" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.exelgramm.ui.profile.ChatConfigFragment"
        android:label="@string/nav_settings" />

    <fragment
        android:id="@+id/nav_participants"
        android:name="com.example.exelgramm.ui.participants.ParticipantsFragment"
        android:label="@string/nav_participants">
        <action
            android:id="@+id/action_participants_to_detail"
            app:destination="@id/participantDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/participantDetailFragment"
        android:name="com.example.exelgramm.ui.participants.ParticipantDetailFragment"
        android:label="@string/participant_detail_title">
        <argument
            android:name="authorName"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>
